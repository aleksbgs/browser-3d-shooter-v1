# -----------------------------------------------------------------------------
# Game server (Node / Colyseus). Loaded by server via dotenv; Docker sets these too.
# -----------------------------------------------------------------------------
PORT=2567
# Alternative to PORT (same meaning); ignored if PORT is set
# COLYSEUS_PORT=2567
# Must match VITE_COLYSEUS_ROOM_NAME on the client
COLYSEUS_ROOM_NAME=pirate_shooter_v2

# -----------------------------------------------------------------------------
# Browser client (Vite). Only variables prefixed with VITE_ are exposed in the bundle.
# -----------------------------------------------------------------------------
# Explicit WebSocket URL (overrides host/port below)
VITE_COLYSEUS_URL=ws://localhost:2567

# Used to build ws:// when VITE_COLYSEUS_URL is unset (defaults to the page hostname in the browser)
# VITE_COLYSEUS_HOST=localhost
# VITE_COLYSEUS_PORT=2567

# Must match COLYSEUS_ROOM_NAME on the server
VITE_COLYSEUS_ROOM_NAME=pirate_shooter_v2

# Set to true only if you want to disable Colyseus entirely in the client bundle
# VITE_COLYSEUS_DISABLED=true

# -----------------------------------------------------------------------------
# Docker Compose — substitutions in docker-compose.yml (optional; copy to .env)
# -----------------------------------------------------------------------------
# COLYSEUS_PORT=2567
# COLYSEUS_WS_HOST=localhost
# COLYSEUS_ROOM_NAME=pirate_shooter_v2
# WEB_HOST_PORT=8080
# For the web image build (optional; overrides host/port parts for Vite build)
# VITE_COLYSEUS_URL=ws://localhost:2567
